# ─── Required ────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey (free tier works)
GEMINI_API_KEY=your_key_here

# ─── Optional model overrides ────────────────────────────────────
# Live API model — used for the customer voice page (/) and the
# operator copilot's mic STT (/agent). Pro tier improves Uzbek
# recognition but adds ~1.5× latency.
#   gemini-3.1-flash-live-preview   (default, known-good)
#   gemini-3.1-pro-live-preview     (untested in current API)
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Per-turn analysis model on the operator copilot. Flash-lite hits
# the spec's <2s latency target. Switch to gemini-2.5-pro if you
# can wait ~20s per turn for higher quality JSON.
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash-lite

# QA Review model (offline post-call analysis, /agent/qa). Pro is
# fine here — managers don't need real-time response.
GEMINI_QA_MODEL=gemini-2.5-pro
